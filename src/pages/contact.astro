---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact"
  description="Contact information for Dr. Lars Gabriel."
  bannerImage="/banners/banner5.jpg"
  bannerHeight="180px"
  bannerPosition="center 45%"
>
  <main class="container">
    <section class="hero">
      <div class="hero__text">
        <p class="hero__eyebrow">Contact</p>
        <h1 class="hero__title">Get in Touch</h1>
        <p class="hero__subtitle">
          For collaborations, questions, or general inquiries.
        </p>
        <p class="hero__intro">
          The best way to reach me is by email. I am especially happy to hear about
          collaborations involving genome annotation, gene prediction, bioinformatics workflows,
          research software, or deep learning for biological sequence analysis.
        </p>
      </div>
    </section>

    <section class="section section--split">
      <div>
        <h2>Good Reasons to Contact Me</h2>
        <ul class="reason-list">
          <li>Collaboration on eukaryotic genome annotation projects</li>
          <li>Questions about Tiberius, BRAKER3, TSEBRA, or related workflows</li>
          <li>Consulting or applied bioinformatics work</li>
          <li>Talks, workshops, teaching, or research visits</li>
        </ul>

        <h2>Contact</h2>

        <a class="contact-card contact-card--primary" href="mailto:mail@larsgabriel.de">
          <span class="contact-card__icon" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="5" width="18" height="14" rx="2"></rect>
              <path d="M3 7l9 6 9-6"></path>
            </svg>
          </span>
          <div class="contact-card__body">
            <p class="contact-card__label">Email &middot; preferred</p>
            <p class="contact-card__value">mail@larsgabriel.de</p>
            <p class="contact-card__note">I usually reply within a few business days.</p>
          </div>
          <span class="contact-card__cta" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="5" y1="12" x2="19" y2="12"></line>
              <polyline points="12 5 19 12 12 19"></polyline>
            </svg>
          </span>
        </a>

        <h2>Online Profiles</h2>

        <div class="profile-grid">
          <a class="contact-card" href="https://scholar.google.de/citations?user=ZQTdgRYAAAAJ&hl=de" target="_blank" rel="noopener noreferrer">
            <span class="contact-card__icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 10L12 4 2 10l10 6 10-6z"></path>
                <path d="M6 12v5c3 2 9 2 12 0v-5"></path>
              </svg>
            </span>
            <div class="contact-card__body">
              <h3>Google Scholar</h3>
              <p class="muted">Citation profile &amp; publications</p>
              <p class="contact-card__handle contact-card__handle--pill">
                <span>View profile</span>
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <line x1="7" y1="17" x2="17" y2="7"></line>
                  <polyline points="7 7 17 7 17 17"></polyline>
                </svg>
              </p>
            </div>
          </a>

          <a class="contact-card" href="https://orcid.org/0000-0003-0264-016X" target="_blank" rel="noopener noreferrer">
            <span class="contact-card__icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="9"></circle>
                <line x1="9" y1="9" x2="9" y2="17"></line>
                <circle cx="9" cy="7" r="0.6" fill="currentColor"></circle>
                <path d="M12 9h2.5a4 4 0 0 1 0 8H12V9z"></path>
              </svg>
            </span>
            <div class="contact-card__body">
              <h3>ORCID</h3>
              <p class="muted">Researcher identifier</p>
              <p class="contact-card__handle contact-card__handle--pill">
                <span>View profile</span>
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <line x1="7" y1="17" x2="17" y2="7"></line>
                  <polyline points="7 7 17 7 17 17"></polyline>
                </svg>
              </p>
            </div>
          </a>

          <a class="contact-card" href="https://github.com/larsgab" target="_blank" rel="noopener noreferrer">
            <span class="contact-card__icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M9 19c-4 1.5-4-2-6-2.5M15 22v-3.9a3.4 3.4 0 0 0-.9-2.6c3-.3 6-1.5 6-6.5a5 5 0 0 0-1.4-3.5 4.7 4.7 0 0 0-.1-3.5s-1.1-.3-3.6 1.4a12.3 12.3 0 0 0-6.5 0C5.9 1.7 4.8 2 4.8 2a4.7 4.7 0 0 0-.1 3.5 5 5 0 0 0-1.4 3.5c0 5 3 6.2 6 6.5a3.4 3.4 0 0 0-.9 2.6V22"></path>
              </svg>
            </span>
            <div class="contact-card__body">
              <h3>GitHub</h3>
              <p class="muted">Code &amp; research software</p>
              <p class="contact-card__handle contact-card__handle--pill">
                <span>View profile</span>
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <line x1="7" y1="17" x2="17" y2="7"></line>
                  <polyline points="7 7 17 7 17 17"></polyline>
                </svg>
              </p>
            </div>
          </a>

          <a class="contact-card" href="https://www.linkedin.com/in/lars-gabriel-39a2002b1/" target="_blank" rel="noopener noreferrer">
            <span class="contact-card__icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-4 0v7h-4v-7a6 6 0 0 1 6-6z"></path>
                <rect x="2" y="9" width="4" height="12"></rect>
                <circle cx="4" cy="4" r="2"></circle>
              </svg>
            </span>
            <div class="contact-card__body">
              <h3>LinkedIn</h3>
              <p class="muted">Professional profile</p>
              <p class="contact-card__handle contact-card__handle--pill">
                <span>View profile</span>
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <line x1="7" y1="17" x2="17" y2="7"></line>
                  <polyline points="7 7 17 7 17 17"></polyline>
                </svg>
              </p>
            </div>
          </a>
        </div>
      </div>

      <aside class="side-card">
        <p class="side-card__label">Mailing address</p>
        <h2>Address</h2>
        <p>
          Dr. Lars Gabriel<br />
          Institute of Mathematics and Computer Science<br />
          University of Greifswald
        </p>
        <p>
          Walther-Rathenau-Strasse 47, Room 1.16<br />
          17489 Greifswald<br />
          Germany
        </p>
      </aside>
    </section>
  </main>
</BaseLayout>

<style>
  .container {
    width: min(1040px, calc(100% - 2rem));
    margin: 0 auto;
    padding: var(--space-sm) 0 calc(var(--space-xl) 1.3);
  }

  .hero {
    padding: var(--space-sm) 0 var(--space-xl);
    border-bottom: 1px solid var(--color-border);
  }

  .hero__eyebrow {
    font-family: var(--font-ui);
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: var(--space-md);
  }

  .hero__title {
    margin-bottom: var(--space-sm);
  }

  .hero__subtitle {
    font-size: 1.05rem;
    line-height: 1.6;
    color: var(--color-text-muted);
    margin-bottom: var(--space-md);
    max-width: 44ch;
  }

  .hero__intro {
    max-width: 68ch;
    color: var(--color-text);
    line-height: 1.75;
    margin: 0;
  }

  .section {
    padding-top: var(--space-xl);
  }

  .section--split {
    display: grid;
    grid-template-columns: 1.6fr 1fr;
    gap: var(--space-xl);
    align-items: start;
  }

  h2 {
    font-family: var(--font-ui);
    font-size: 0.8rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin: 0 0 var(--space-lg);
  }

  .reason-list {
    display: grid;
    gap: 0.65rem;
    list-style: none;
    padding: 0;
    margin: 0 0 var(--space-xl);
    max-width: 72ch;
  }

  .reason-list li {
    position: relative;
    padding-left: 1.1rem;
    line-height: 1.7;
    color: var(--color-text);
  }

  .reason-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.75em;
    width: 0.38rem;
    height: 0.38rem;
    border-radius: 999px;
    background: var(--color-text);
  }

  /* Contact card - clean, elevated, with icon column */
  .contact-card {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-md);
    align-items: start;
    position: relative;
    overflow: hidden;
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border-soft);
    border-radius: var(--radius-md);
    padding: 1.25rem 1.75rem;
    box-shadow: var(--shadow-xs);
    text-decoration: none;
    color: var(--color-text);
    transition: transform var(--transition-base),
                box-shadow var(--transition-base),
                border-color var(--transition-base);
  }

  .contact-card::before {
    content: '';
    position: absolute;
    left: 0;
    top: 20%;
    bottom: 20%;
    width: 3px;
    background: var(--color-text);
    border-radius: 0 2px 2px 0;
    transition: top var(--transition-base), bottom var(--transition-base);
  }

  .contact-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
    border-color: var(--color-border);
    opacity: 1;
  }

  .contact-card:hover::before {
    top: 0;
    bottom: 0;
  }

  .contact-card__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: var(--radius-sm);
    background: var(--color-bg-alt);
    color: var(--color-text);
    border: 1px solid var(--color-border-soft);
    flex-shrink: 0;
  }

  .contact-card__body {
    min-width: 0;
  }

  .contact-card h3 {
    font-family: var(--font-ui);
    font-size: 1.05rem;
    margin: 0 0 0.2rem;
    letter-spacing: -0.005em;
    color: var(--color-text);
  }

  .contact-card .muted {
    margin: 0 0 0.45rem;
    font-size: 0.92rem;
    line-height: 1.5;
  }

  .contact-card__handle {
    margin: 0;
    font-family: var(--font-ui);
    font-weight: 600;
    font-size: 0.92rem;
    color: var(--color-text);
    overflow-wrap: anywhere;
  }

  .contact-card__handle--pill {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.4rem;
    white-space: nowrap;
    overflow-wrap: normal;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.4rem 0.8rem;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    background: transparent;
    transition: background var(--transition-fast),
                border-color var(--transition-fast),
                color var(--transition-fast);
  }

  .contact-card:hover .contact-card__handle--pill {
    background: var(--color-text);
    color: var(--color-bg);
    border-color: var(--color-text);
    text-decoration: none;
  }

  .contact-card:hover .contact-card__handle {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  /* Primary email card - clean white surface matching card style */
  .contact-card--primary {
    grid-template-columns: auto 1fr auto;
    margin-bottom: var(--space-xl);
    background: var(--color-bg-alt);
    border-color: var(--color-border-soft);
    color: var(--color-text);
    padding: 1.25rem 1.75rem;
    box-shadow: var(--shadow-sm);
  }

  .contact-card--primary:hover {
    box-shadow: var(--shadow-md);
    border-color: var(--color-border);
  }

  .contact-card--primary .contact-card__icon {
    background: var(--color-bg-alt);
    border-color: var(--color-border-soft);
    color: var(--color-text);
    width: 48px;
    height: 48px;
  }

  .contact-card__label {
    margin: 0 0 0.3rem;
    font-family: var(--font-ui);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .contact-card__value {
    margin: 0 0 0.4rem;
    font-family: var(--font-ui);
    font-size: 1.15rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--color-text);
    overflow-wrap: anywhere;
  }

  .contact-card__note {
    margin: 0;
    font-size: 0.92rem;
    line-height: 1.55;
    color: var(--color-text-muted);
  }

  .contact-card__cta {
    align-self: center;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    border-radius: 999px;
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border-soft);
    color: var(--color-text);
    transition: transform var(--transition-base), background var(--transition-base);
  }

  .contact-card--primary:hover .contact-card__cta {
    transform: translateX(3px);
    background: var(--color-border-soft);
  }

  .muted {
    color: var(--color-text-muted);
  }

  .profile-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-md);
  }

  .profile-grid .contact-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0;
  }

  .profile-grid .contact-card__body {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
    flex: 1;
  }

  .profile-grid .contact-card__body h3 {
    margin-bottom: 0.2rem;
  }

  .profile-grid .contact-card__body .muted {
    margin-bottom: var(--space-sm);
    flex: 1;
  }

  .profile-grid .contact-card__icon {
    margin-bottom: var(--space-sm);
  }

  /* Side card - clean white surface matching card style */
  .side-card {
    position: sticky;
    top: 2rem;
    overflow: hidden;
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border-soft);
    border-radius: var(--radius-md);
    padding: 1.25rem 1.75rem;
    box-shadow: var(--shadow-sm);
    transition: box-shadow var(--transition-base), border-color var(--transition-base);
  }

  .side-card::before {
    content: '';
    position: absolute;
    left: 0;
    top: 20%;
    bottom: 20%;
    width: 3px;
    background: var(--color-text);
    border-radius: 0 2px 2px 0;
    transition: top var(--transition-base), bottom var(--transition-base);
  }

  .side-card:hover {
    box-shadow: var(--shadow-md);
    border-color: var(--color-border);
  }

  .side-card:hover::before {
    top: 0;
    bottom: 0;
  }

  .side-card__label {
    font-family: var(--font-ui);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin: 0 0 var(--space-xs);
  }

  .side-card h2 {
    font-family: var(--font-ui);
    font-size: 1.15rem;
    font-weight: 600;
    margin: 0 0 var(--space-md);
    letter-spacing: -0.01em;
    text-transform: none;
    color: var(--color-text);
  }

  .side-card p {
    margin: 0 0 0.65rem;
    line-height: 1.7;
  }

  @media (max-width: 900px) {
    .section--split,
    .profile-grid {
      grid-template-columns: 1fr;
    }

    .side-card {
      position: static;
    }

    .container {
      width: min(100%, calc(100% - 1.5rem));
    }
  }
</style>

